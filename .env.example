# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://leanstock:leanstock_secret@localhost:5432/leanstock

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secrets (min 32 characters)
JWT_ACCESS_SECRET=change-me-to-a-random-32-char-string!!
JWT_REFRESH_SECRET=change-me-to-another-32-char-string!!
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting (requests per minute)
RATE_LIMIT_AUTH=5

# Dead Stock Decay
DEAD_STOCK_THRESHOLD_DAYS=30
DEAD_STOCK_MARKDOWN_PERCENT=10
DEAD_STOCK_INTERVAL_HOURS=72
DEAD_STOCK_PRICE_FLOOR_PERCENT=40

# Reservations
RESERVATION_TTL_HOURS=24

# CORS
CORS_ORIGIN=http://localhost:3000

# Multi-tenancy
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
